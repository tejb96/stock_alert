DATABASE_URL=sqlite+aiosqlite:///./data/alerts.db
POLL_INTERVAL_SECONDS=60
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
YAHOO_USER_AGENT=stock_alert/0.1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ApeWisdom trend detection (stocks)
APEWISDOM_ENABLED=false
APEWISDOM_FETCH_INTERVAL_MINUTES=60
APEWISDOM_MIN_MENTIONS=20
APEWISDOM_ALERT_MENTIONS=50
APEWISDOM_ALERT_CHANGE_24H=100
APEWISDOM_ALERT_SCORE_THRESHOLD=150
APEWISDOM_ALERT_COOLDOWN_HOURS=6
APEWISDOM_ALERT_MAX_PER_CYCLE=3
APEWISDOM_DAILY_SUMMARY_HOUR_UTC=21
APEWISDOM_HISTORY_DAYS=60
APEWISDOM_TOP_N=50
